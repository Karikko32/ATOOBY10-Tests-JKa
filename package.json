{
  "name": "software-testing-assignment",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "test": "mocha --require @babel/register",
    "coverage": "nyc mocha --require @babel/register \"test/**/*.js\""
  },
  "nyc": {
    "include": [
      "src/**/*.js"
    ],
    "exclude": [
      "test/**/*.js"
    ],
    "extension": [
      ".js"
    ],
    "reporter": [
      "lcov",
      "text"
    ],
    "report-dir": "./coverage",
    "all": true,
    "require": [
      "@babel/register"
    ]
  },
  "author": "JKa",
  "license": "MIT",
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/preset-env": "^7.29.2",
    "@babel/register": "^7.28.6",
    "babel-plugin-istanbul": "^7.0.1",
    "chai": "^6.2.2",
    "mocha": "^11.7.5",
    "nyc": "^15.1.0"
  }
}