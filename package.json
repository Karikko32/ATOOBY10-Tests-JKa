{
  "name": "software-testing-assignment",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "test": "mocha",
    "coverage": "nyc mocha \"test/**/*.js\""
  },
  "nyc": {
    "include": ["src/**/*.js"],
    "exclude": [
      "test/**/*.js",
      "src/.internal/**"
    ],
    "extension": [".js"],
    "reporter": ["lcov", "text"],
    "all": true,
    "sourceMap": false,
    "instrument": true
  },
  "devDependencies": {
    "chai": "^6.2.2",
    "mocha": "^11.7.5",
    "nyc": "^15.1.0"
  }
}